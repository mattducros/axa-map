{
  "artifactStructure": {
    "assets": [
      {
        "root": "dist",
        "pattern": "*.html"
      },
      {
        "root": "dist",
        "pattern": "**/*"
      }
    ]
  },
  "dependencies": {
    "installDepsCmd": "npm install",
    "requiredFiles": ["package.json", "package-lock.json", ".npmrc"]
  },
  "buildArtifacts": {
    "buildCmd": "npm run build"
  },
  "livePreview": {
    "serveSetupCmd": ":"
  }
}